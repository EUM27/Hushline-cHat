{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "corepack pnpm install --frozen-lockfile",
  "buildCommand": "corepack pnpm --filter @hushline/client build",
  "outputDirectory": "packages/client/dist",
  "functions": {
    "api/index.ts": {
      "includeFiles": "packages/server/scenarios/**/*",
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api"
    }
  ]
}
